# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here
BOT_OWNER_ID=your_discord_user_id_here

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?appName=Cluster0
LOGS_URI=mongodb+srv://username:password@cluster.mongodb.net/logs?appName=Cluster0
POG_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pogbot?appName=Cluster0
WISHLIST_URI=mongodb+srv://username:password@cluster.mongodb.net/wishlist?appName=Cluster0

# AWS Configuration (Optional)
AWS_REGION=us-east-1

# Logging Configuration (Optional)
LOG_WEBHOOK_URL=
ERROR_WEBHOOK_URL=

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://default:password@host:port